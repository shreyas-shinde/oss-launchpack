{
  "name": "oss-launchpack",
  "version": "0.3.0",
  "description": "Generate operations-ready launchpacks for popular self-hosted OSS apps.",
  "type": "module",
  "bin": {
    "oss-launchpack": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "rm -rf .tmp/test-build && tsc -p tsconfig.test.json && node --test .tmp/test-build/test/*.test.js",
    "generate": "node dist/cli.js generate",
    "check": "pnpm build && pnpm test"
  },
  "keywords": [
    "open-source",
    "self-hosted",
    "docker-compose",
    "deployment",
    "backup",
    "restore",
    "observability",
    "sentry",
    "analytics",
    "posthog",
    "knowledge-base",
    "outline",
    "backend",
    "postgres",
    "supabase",
    "qdrant",
    "vector-database",
    "rag",
    "meilisearch",
    "search",
    "ai-agents",
    "dify",
    "llmops",
    "oss"
  ],
  "author": "Shreyas Shinde",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "22.10.10",
    "typescript": "^5.8.0"
  }
}
